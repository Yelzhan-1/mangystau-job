# If not set, the app uses deterministic local explanations (works perfectly without a key).
ANTHROPIC_API_KEY=""

# ── Telegram Bot (Prompt 4+) ──
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_URL=""

